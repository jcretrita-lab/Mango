{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "useDefineForClassFields":  true,
                            "lib":  [
                                        "ES2020",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "module":  "ESNext",
                            "skipLibCheck":  true,
                            "moduleResolution":  "bundler",
                            "allowImportingTsExtensions":  true,
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "noEmit":  true,
                            "jsx":  "react-jsx",
                            "strict":  true,
                            "noUnusedLocals":  false,
                            "noUnusedParameters":  false,
                            "noFallthroughCasesInSwitch":  true,
                            "types":  [
                                          "node"
                                      ]
                        },
    "include":  [
                    "App.tsx",
                    "index.tsx",
                    "types.ts",
                    "components/**/*.tsx",
                    "config/**/*.ts",
                    "context/**/*.tsx",
                    "hooks/**/*.ts",
                    "features/**/*.tsx",
                    "pages/**/*.tsx"
                ],
    "references":  [
                       {
                           "path":  "./tsconfig.node.json"
                       }
                   ]
}
